<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="uflite_gripper">
  <xacro:macro name="uflite_gripper_urdf" params="prefix:='' attach_to:='' attach_xyz:='0 0 0' attach_rpy:='0 0 0' gripper_version:='G1' ">

    <xacro:property name="name_suffix" value=""/>
    <xacro:if value="${mesh_suffix == 'dae'}">
      <xacro:if value="${gripper_version == 'G2' or gripper_version == 'g2'}">
        <xacro:property name="name_suffix" value="_g2"/>
      </xacro:if>
    </xacro:if>

    <xacro:unless value="${attach_to == ''}">
      <joint name="${prefix}gripper_fix" type="fixed">
        <parent link="${attach_to}"/>
        <child link="${prefix}uflite_gripper_link"/>
        <origin xyz="${attach_xyz}" rpy="${attach_rpy}"/>
      </joint>
    </xacro:unless>
    
    <link name="${prefix}uflite_gripper_link">
      <inertial>
        <origin xyz="0.0 0.0 0.030" rpy="0 0 0" />
        <mass value="0.25" />
        <inertia
          ixx="0.00047106" ixy="3.9292E-07" ixz="2.6537E-06"
          iyy="0.00033072" iyz="-1.0975E-05" izz="0.00025642" />
      </inertial>
      <xacro:common_link_visual 
        mesh_filename="gripper/lite/visual/shell"  
        origin_xyz="0 0 0" 
        origin_rpy="0 0 0"
        material_name="${prefix}White" />
      <xacro:common_link_collision 
        mesh_filename="gripper/lite/visual/shell"  
        origin_xyz="0 0 0" 
        origin_rpy="0 0 0" />
    </link>

    <link name="${prefix}uflite_finger1">
      <inertial>
        <origin xyz="0.0 0.01 0.0086" rpy="0 0 0" />
        <mass value="0.0163" />
        <inertia
          ixx="1.425E-06" ixy="0.0" ixz="0.0"
          iyy="1.63E-06" iyz="-3.1E-07" izz="8.63E-07" />
      </inertial>
      <xacro:common_link_visual 
        mesh_filename="gripper/lite/visual/finger1${name_suffix}"  
        origin_xyz="0 0 0" 
        origin_rpy="0 0 0"
        material_name="${prefix}White" />
      <xacro:common_link_collision 
        mesh_filename="gripper/lite/visual/finger1${name_suffix}"  
        origin_xyz="0 0 0" 
        origin_rpy="0 0 0" />
    </link>
    <joint name="${prefix}finger_joint1" type="prismatic">
      <origin xyz="0 0 0.0543" rpy="0 0 0" />
      <parent link="${prefix}uflite_gripper_link" />
      <child link="${prefix}uflite_finger1" />
      <axis xyz="0 1 0" />
      <limit effort="5" lower="0" upper="0.0089" velocity="2"/>
    </joint>

    <link name="${prefix}uflite_finger2">
      <inertial>
        <origin xyz="0.0 -0.01 0.0086" rpy="0 0 0" />
        <mass value="0.0163" />
        <inertia
          ixx="1.425E-06" ixy="0.0" ixz="0.0"
          iyy="1.63E-06" iyz="3.1E-07" izz="8.63E-07" />
      </inertial>
      <xacro:common_link_visual 
        mesh_filename="gripper/lite/visual/finger2${name_suffix}"  
        origin_xyz="0 0 0" 
        origin_rpy="0 0 0"
        material_name="${prefix}White" />
      <xacro:common_link_collision 
        mesh_filename="gripper/lite/visual/finger2${name_suffix}"  
        origin_xyz="0 0 0" 
        origin_rpy="0 0 0" />
    </link>
    <joint name="${prefix}finger_joint2" type="prismatic">
      <origin xyz="0 0 0.0543" rpy="0 0 0" />
      <parent link="${prefix}uflite_gripper_link" />
      <child link="${prefix}uflite_finger2" />
      <axis xyz="0 -1 0" />
      <limit effort="5" lower="0" upper="0.0089" velocity="2"/>
      <mimic joint="${prefix}finger_joint1" multiplier="1" offset="0"/>
    </joint>

    <link name="${prefix}link_tcp" />

    <joint name="${prefix}joint_tcp" type="fixed">
      <origin xyz="0 0 0.0836" rpy="0 0 0" />
      <parent link="${prefix}uflite_gripper_link" />
      <child link="${prefix}link_tcp" />
    </joint>

  </xacro:macro>

</robot>